{
    "compilerOptions": {
        "target": "es2022",
        "lib": ["es2022"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "declaration": true,
        "sourceMap": true,
        "resolveJsonModule": true,
        "allowJs": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "noImplicitAny": true,
        "skipLibCheck": true,
        "noUnusedLocals": false,
        "removeComments": true,
        "types": ["node", "vitest/globals"],
        "paths": {
            "@prostojs/parser": ["./lib/src/index.ts"]
        }
    },
    "include": [
        "lib/src/**/*.ts",
        "lib/tests/**/*.ts",
        "examples/*/src/**/*.ts",
        "examples/*/tests/**/*.ts",
        "bench/**/*.ts"
    ],
    "exclude": ["node_modules", "dist"]
}
