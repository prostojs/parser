{
    "name": "@prostojs/parser-monorepo",
    "version": "0.5.11",
    "private": true,
    "description": "Parse anything — a composable, hooks-based parser toolkit",
    "license": "MIT",
    "author": "Artem Maltsev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/prostojs/parser.git"
    },
    "type": "module",
    "scripts": {
        "build": "rolldown -c rolldown.config.mjs && rollup -c rollup.dts.config.mjs",
        "test": "vitest run",
        "test:cov": "vitest run --coverage",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "release": "node ./scripts/release.cjs",
        "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
        "version": "conventional-changelog -p angular -i CHANGELOG.md -s && git add CHANGELOG.md"
    },
    "devDependencies": {
        "@prostojs/dye": "^0.4.9",
        "@types/node": "^22.19.13",
        "conventional-changelog": "^3.1.25",
        "conventional-changelog-cli": "^2.2.2",
        "enquirer": "^2.4.1",
        "execa": "^5.1.1",
        "fs-extra": "^10.1.0",
        "minimist": "^1.2.8",
        "oxfmt": "^0.36.0",
        "oxlint": "^1.51.0",
        "rollup": "^4.59.0",
        "rollup-plugin-dts": "^6.3.0",
        "rolldown": "^1.0.0-rc.7",
        "semver": "^7.7.4",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    },
    "gitHooks": {
        "commit-msg": "node scripts/verifyCommit.cjs"
    }
}
